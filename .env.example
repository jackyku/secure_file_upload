# ─────────────────────────────────────────────────────────────
#  Web Upload Server — Environment Configuration
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Session ─────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# ── Server ──────────────────────────────────────────────────
PORT=3000

# ── Database ─────────────────────────────────────────────────
# Leave blank to use local SQLite (recommended for single-server setups).
# Set a PostgreSQL URL to use Postgres instead.
# DATABASE_URL=postgres://user:password@localhost:5432/dbname

# ── Upload limits ────────────────────────────────────────────
# Maximum single file size in bytes (default: 1 TB)
# MAX_UPLOAD_BYTES=1099511627776

# Chunk size for resumable uploads in bytes (default: 8 MB)
# CHUNK_SIZE=8388608

# Max simultaneous uploads per user (default: 3)
# MAX_CONCURRENT_UPLOADS_PER_USER=3

# Max simultaneous uploads across all users (default: 100)
# MAX_GLOBAL_CONCURRENT_UPLOADS=100
